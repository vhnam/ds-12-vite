{
  "name": "@ds-12/ui",
  "version": "0.0.0",
  "description": "A starter for creating a TypeScript package.",
  "homepage": "https://github.com/author/library#readme",
  "bugs": {
    "url": "https://github.com/author/library/issues"
  },
  "license": "MIT",
  "author": "Author Name <author.name@mail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/author/library.git"
  },
  "files": [
    "dist",
    "src/tailwind.css"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "imports": {
    "#lib/*": "./src/lib/*",
    "#components/*": "./src/components/*"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./avatar": "./dist/avatar.mjs",
    "./badge": "./dist/badge.mjs",
    "./button": "./dist/button.mjs",
    "./chip": "./dist/chip.mjs",
    "./checkbox": "./dist/checkbox.mjs",
    "./divider": "./dist/divider.mjs",
    "./fields/input-field": "./dist/fields/input-field.mjs",
    "./fields/select-field": "./dist/fields/select-field.mjs",
    "./fields/combobox-field": "./dist/fields/combobox-field.mjs",
    "./fields/textarea-field": "./dist/fields/textarea-field.mjs",
    "./fields/checkbox-field": "./dist/fields/checkbox-field.mjs",
    "./fields/radio-field": "./dist/fields/radio-field.mjs",
    "./fields/switch-field": "./dist/fields/switch-field.mjs",
    "./icon": "./dist/icon.mjs",
    "./input": "./dist/input.mjs",
    "./select": "./dist/select.mjs",
    "./menu": "./dist/menu.mjs",
    "./combobox": "./dist/combobox.mjs",
    "./pagination": "./dist/pagination.mjs",
    "./radio": "./dist/radio.mjs",
    "./table": "./dist/table.mjs",
    "./skeleton": "./dist/skeleton.mjs",
    "./switch": "./dist/switch.mjs",
    "./textarea": "./dist/textarea.mjs",
    "./typography": "./dist/typography.mjs",
    "./style.css": "./dist/style.css",
    "./tailwind.css": "./src/tailwind.css",
    "./tokens.css": "@ds-12/design-tokens/tokens.css",
    "./theme.css": "@ds-12/design-tokens/theme.css",
    "./material-symbols.css": "@material-symbols/font-400/outlined.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@base-ui/react": "^1.0.0",
    "@ds-12/design-tokens": "workspace:*",
    "@material-symbols/font-400": "^0.40.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "catalog:"
  },
  "devDependencies": {
    "@tsdown/css": "^0.22.3",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0"
  }
}
