{
  "name": "@ds-12/design-tokens",
  "version": "0.0.0",
  "description": "A starter for creating a TypeScript package.",
  "homepage": "https://github.com/author/library#readme",
  "bugs": {
    "url": "https://github.com/author/library/issues"
  },
  "license": "MIT",
  "author": "Author Name <author.name@mail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vhnam/ds-12-vite.git",
    "directory": "packages/design-tokens"
  },
  "files": [
    "dist",
    "src/tokens.generated.css",
    "src/tokens.web.css",
    "src/tokens.theme.css"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./tokens.css": "./src/tokens.web.css",
    "./tokens.generated.css": "./src/tokens.generated.css",
    "./theme.css": "./src/tokens.theme.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/generate-theme.mjs && vp pack",
    "dev": "node scripts/generate-theme.mjs && vp pack --watch",
    "generate:theme": "node scripts/generate-theme.mjs",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "build:tokens": "tsx src/index.ts"
  },
  "dependencies": {
    "@tokens-studio/sd-transforms": "catalog:",
    "style-dictionary": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "bumpp": "^11.1.0",
    "tsx": "catalog:",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:"
  }
}
